# ~/.config/zsh/env.zsh - Environment variables (no secrets)

# Starship config location
export STARSHIP_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/starship/starship.toml"

# Editors & Pagers
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="less -R"
export LESSHISTFILE="-"

# Dev Paths (prepend, don't replace)
path=(
  $HOME/go/bin
  $HOME/.cargo/bin
  $HOME/.local/bin
  $path
)

# Zsh completions — must be on fpath before compinit (completions.zsh)
fpath+=("${XDG_DATA_HOME:-$HOME/.local/share}/zsh/site-functions")
[[ -d /opt/homebrew/share/zsh/site-functions ]] && fpath+=(/opt/homebrew/share/zsh/site-functions)
[[ -d /usr/local/share/zsh/site-functions ]] && fpath+=(/usr/local/share/zsh/site-functions)
[[ -d /usr/share/zsh/vendor-completions ]] && fpath+=(/usr/share/zsh/vendor-completions)

# Git
export GIT_PAGER="delta"
export DELTA_PAGER="less -R"

# Projects for Project Jump (pj)
export PROJECT_PATHS=(~/projects ~/dev)

# Language Runtimes (mise manages versions)
{{- if .enable_node }}
export NODE_ENV="development"
{{- end }}
{{- if .enable_python }}
export PYTHONUNBUFFERED="1"
export PIP_NO_INPUT="1"
{{- end }}

# Kubernetes
export KUBECONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/kube/config"

# Docker
export DOCKER_CLI_EXPERIMENTAL="enabled"

# Disable slow features
export DISABLE_AUTO_TITLE="true"  # Prevent terminal title flicker
