#!/usr/bin/env zsh
# ~/.zshrc - Managed by chezmoi. Edit source, not this file.
# Source: {{ .chezmoi.sourceFile }}

# ============================================================================
# XDG Base Directories (set early)
# ============================================================================
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# ============================================================================
# Locale Fallback (safe default)
# ============================================================================
if ! locale -a 2>/dev/null | grep -qi 'en_US.utf8'; then
  export LC_ALL=C.UTF-8
  export LANG=C.UTF-8
  export LANGUAGE=C.UTF-8
fi

# ============================================================================
# History (XDG-compliant)
# ============================================================================
HISTFILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"
mkdir -p "$(dirname "$HISTFILE")"
SAVEHIST=10000
HISTSIZE=10000
setopt SHARE_HISTORY HIST_EXPIRE_DUPS_FIRST HIST_IGNORE_DUPS HIST_VERIFY

# ============================================================================
# PATH – consistent prepend order
# ============================================================================
export PATH="$HOME/.local/bin:$PATH"
{{- if eq .chezmoi.os "darwin" }}
export PATH="/opt/homebrew/bin:$PATH"
{{- end }}

# ============================================================================
# OS Detection Variable (for aliases/functions)
# ============================================================================
export DOTFILES_OS="{{ .chezmoi.os }}"  # "darwin" or "linux"

# ============================================================================
# Load Modular Configs (split for maintainability)
# ============================================================================
ZSH_MODULES="$XDG_CONFIG_HOME/zsh"
for module in env aliases functions completions; do
  [[ -r "$ZSH_MODULES/$module.zsh" ]] && source "$ZSH_MODULES/$module.zsh"
done

# ============================================================================
# Plugin Manager: zinit (managed via .chezmoiexternal.yaml)
# ============================================================================
ZINIT_HOME="$XDG_DATA_HOME/zinit/zinit.git"
if [[ -d "$ZINIT_HOME" ]]; then
  source "$ZINIT_HOME/zinit.zsh"

  # OMZ snippets (lightweight, no full oh-my-zsh)
  zinit snippet OMZL::git.zsh
  zinit snippet OMZL::directories.zsh
  zinit snippet OMZL::history.zsh
  zinit snippet OMZP::git
  zinit snippet OMZP::direnv

  # Core UX plugins
  zinit ice wait"0" lucid; zinit light zsh-users/zsh-syntax-highlighting
  zinit ice wait"0" lucid; zinit light zsh-users/zsh-autosuggestions
  zinit ice wait"0" lucid; zinit light MichaelAquilina/zsh-you-should-use

  # fzf-tab (only if fzf present)
  if (( $+commands[fzf] )); then
    zinit ice wait"0" lucid; zinit light Aloxaf/fzf-tab
    zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
    zstyle ':fzf-tab:complete:ls:*' fzf-preview '[[ -f $realpath ]] && bat --color=always $realpath || eza -1 --color=always $realpath'
    zstyle ':fzf-tab:complete:git-checkout:*' fzf-preview 'git diff --color=always $word'
  fi

  # Completions
  zinit ice wait"1" lucid atload"zicompinit; zicdreplay"; zinit light zsh-users/zsh-completions
fi

# ============================================================================
# Tool Initializations (only if installed)
# ============================================================================
# mise (polyglot runtime manager)
if (( $+commands[mise] )); then
  eval "$(mise activate zsh)"
  {{- if eq .chezmoi.os "darwin" }}
  export PNPM_HOME="$HOME/Library/pnpm"
  {{- else }}
  export PNPM_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/pnpm"
  {{- end }}
  export PATH="$PNPM_HOME:$PATH"
fi

# starship prompt
if (( $+commands[starship] )); then
  eval "$(starship init zsh)"
fi

# zoxide (smart cd)
if (( $+commands[zoxide] )); then
  eval "$(zoxide init zsh)"
fi

# atuin (synced history - optional)
if [[ -f "$HOME/.atuin/bin/env" ]]; then
  . "$HOME/.atuin/bin/env"
  eval "$(atuin init zsh)"
fi

# ============================================================================
# SSH Agent (keychain) – only if installed
# ============================================================================
if (( $+commands[keychain] )); then
  # eval $(keychain --eval --quiet --agents ssh --ignore-missing ~/.ssh/id_{ecdsa,ed25519,rsa} 2>/dev/null)
  eval $(keychain --eval --quiet 2>/dev/null)
elif [[ "$DOTFILES_OS" == "linux" ]]; then
  # Fallback: gpg-agent as SSH agent (common on Linux)
  if command -v gpg-connect-agent &>/dev/null; then
    export SSH_AUTH_SOCK="$(gpgconf --list-dirs agent-ssh-socket 2>/dev/null)"
    gpg-connect-agent updatestartuptty /bye >/dev/null 2>&1
  fi
fi

# ============================================================================
# Debian/Ubuntu Compatibility Aliases
# ============================================================================
(( ! $+commands[fd] && $+commands[fdfind] )) && alias fd='fdfind'
(( ! $+commands[bat] && $+commands[batcat] )) && alias bat='batcat'

# ============================================================================
# VS Code Shell Integration
# ============================================================================
[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh 2>/dev/null)"

# ============================================================================
# FZF History Binding (safe fallback)
# ============================================================================
if (( $+functions[fzf-history-widget] )); then
  bindkey '^R' fzf-history-widget
fi

# ============================================================================
# Missing Tools Reminder (non-blocking)
# ============================================================================
missing=()
(( ! $+commands[eza] )) && missing+=("eza")
(( ! $+commands[bat] && ! $+commands[batcat] )) && missing+=("bat/batcat")
(( ! $+commands[rg] )) && missing+=("rg")
(( ! $+commands[fzf] )) && missing+=("fzf")
(( ! $+commands[delta] )) && missing+=("delta")
(( ${#missing} )) && echo "⚠️ Optional tools missing: ${(j:, :)missing} → run: chezmoi apply && ~/.local/share/chezmoi/run_once_install_cli_tools.sh"
